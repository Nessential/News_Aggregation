# Copy this file to `.env` and fill in real values for your environment.

# MySQL
MYSQL_URL=jdbc:mysql://127.0.0.1:3306/news-aggregation
MYSQL_USERNAME=root
MYSQL_PASSWORD=

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_DATABASE=0
REDIS_TIMEOUT=2000ms

# Nacos
NACOS_ADDR=localhost:8849
NACOS_NAMESPACE=news-agent
NACOS_USERNAME=
NACOS_PASSWORD=
NACOS_MCP_GROUP_ID=MCP_TOOLS

# DashScope
DASHSCOPE_API_KEY=
DASHSCOPE_CHAT_MODEL=qwen3.5-flash
DASHSCOPE_CHAT_TEMPERATURE=0.7
DASHSCOPE_CHAT_MAX_TOKENS=10000
DASHSCOPE_EMBEDDING_MODEL=text-embedding-v2
DASHSCOPE_AGENT_CHAT_MODEL=qwen3.5-plus
DASHSCOPE_AGENT_CHAT_TEMPERATURE=0.7

# Zhipu
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_EMBEDDING_MODEL=embedding-3
ZHIPU_EMBEDDING_DIMENSIONS=2048
ZHIPU_CONNECT_TIMEOUT=10000
ZHIPU_READ_TIMEOUT=30000
ZHIPU_LLM_READ_TIMEOUT=60000
ZHIPU_CHAT_MODEL=glm-4
ZHIPU_CHAT_LITE_MODEL=glm-4-flash
ZHIPU_CHAT_TEMPERATURE=0.7
ZHIPU_CHAT_MAX_TOKENS=2048

# Qdrant
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_USE_TLS=false
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=news_chunks_zh
QDRANT_VECTOR_SIZE=2048
QDRANT_COLLECTION_CHUNKS_EN=news_chunks_en
QDRANT_COLLECTION_CHUNKS_ZH=news_chunks_zh
QDRANT_COLLECTION_TOPIC_EN=news_topic_en
QDRANT_COLLECTION_TOPIC_ZH=news_topic_zh

# Elasticsearch
ES_HOST=localhost
ES_PORT=9200
ES_USERNAME=
ES_PASSWORD=
ES_INDEX=news_articles

# MinIO
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=
MINIO_BUCKET=news-image

# XXL-Job
XXL_JOB_ADMIN_ADDRESSES=http://127.0.0.1:8090/xxl-job-admin
XXL_JOB_ACCESS_TOKEN=
XXL_JOB_EXECUTOR_APPNAME=news-aggregation-executor
XXL_JOB_EXECUTOR_PORT=9999
XXL_JOB_EXECUTOR_IP=127.0.0.1
XXL_JOB_ADMIN_TIMEOUT=3

# Optional existing integrations
BAIDU_TRANSLATE_APP_ID=
BAIDU_TRANSLATE_SECRET_KEY=
ALIBABA_CLOUD_ACCESS_KEY_ID=
ALIBABA_CLOUD_ACCESS_KEY_SECRET=
