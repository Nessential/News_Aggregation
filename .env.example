# 环境变量配置模板
# 复制此文件为 .env 并填入真实的配置值

# 百度翻译 API 配置
# 从百度翻译开放平台获取：https://fanyi-api.baidu.com/
BAIDU_TRANSLATE_APP_ID=your-baidu-app-id
BAIDU_TRANSLATE_SECRET_KEY=your-baidu-secret-key

# 智谱 AI Embedding API 配置  
# 从智谱AI开放平台获取：https://open.bigmodel.cn/
ZHIPU_API_KEY=your-zhipu-api-key

# 阿里云 密钥:用于短信验证码发送
ALIBABA_CLOUD_ACCESS_KEY_ID=xxxx
ALIBABA_CLOUD_ACCESS_KEY_SECRET=xxx

