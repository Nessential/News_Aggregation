<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.news.aggregation.news.infrastructure.mapper.NewsMapper">

    <resultMap id="resultNewsMap" type="com.example.news.aggregation.news.domain.entity.News">
        <!-- 主键 -->
        <id column="id" property="id" jdbcType="BIGINT"/>
        
        <!-- 基础字段 -->
        <result column="title" property="title" jdbcType="VARCHAR"/>
        <result column="summary" property="summary" jdbcType="VARCHAR"/>
        <result column="image_url" property="image_url" jdbcType="VARCHAR"/>
        <result column="link" property="link" jdbcType="VARCHAR"/>
        <result column="source" property="source" jdbcType="CHAR"/>
        <result column="publication_time" property="publication_time" jdbcType="BIGINT"/>
        <result column="context" property="context" jdbcType="LONGVARCHAR"/>

        <result column="context_cn" property="context_cn" jdbcType="LONGVARCHAR"/>
        <result column="title_cn" property="title_cn" jdbcType="VARCHAR"/>
        <result column="summary_cn" property="summary_cn" jdbcType="LONGVARCHAR"/>

        <result column="content_status" property="content_status" jdbcType="TINYINT"/>
        <result column="translation_status" property="translation_status" jdbcType="TINYINT"/>
        
        <!-- 向量化相关字段 -->
        <result column="vector_status" property="vector_status" jdbcType="TINYINT"/>
        <result column="canonical_id" property="canonical_id" jdbcType="VARCHAR"/>
        <result column="canonical_status" property="canonical_status" jdbcType="TINYINT"/>
        
        <!-- BaseEntity 继承字段 -->
        <result column="deleted" property="deleted" jdbcType="TINYINT"/>
        <result column="lock_version" property="lockVersion" jdbcType="INTEGER"/>
        <result column="gmt_create" property="gmtCreate" jdbcType="TIMESTAMP"/>
        <result column="gmt_modified" property="gmtModified" jdbcType="TIMESTAMP"/>
    </resultMap>


    <select id="selectByLink" resultMap="resultNewsMap">
        select * from news where link = #{link} and deleted = 0 limit 1
    </select>


    <!-- 查询待翻译的新闻（正文已抓取成功，翻译未完成） -->
    <select id="selectForTranslation" resultMap="resultNewsMap">
        select * from news where content_status = 1
        and translation_status = 0
        and deleted = 0
        order by gmt_create asc
        limit #{batchSize}
    </select>


<!--    查找翻译完成，但是还没向量化的新闻数据-->
 <select id="selectForVectorization" resultMap="resultNewsMap">
      SELECT * FROM news
    WHERE deleted = 0
      AND translation_status = 1
       AND (vector_status IS NULL OR vector_status = 0)
     ORDER BY id ASC
     LIMIT #{batchSize}

 </select>

    <select id="selectListPage" resultMap="resultNewsMap">
        SELECT * FROM news
        <where>
            deleted = 0
            <if test="keyword != null and keyword != ''">
                AND (
                title LIKE CONCAT('%', #{keyword}, '%')
                OR summary LIKE CONCAT('%', #{keyword}, '%')
                OR title_cn LIKE CONCAT('%', #{keyword}, '%')
                OR summary_cn LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="source != null and source != ''">
                AND source = #{source}
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
        </where>
        ORDER BY publication_time DESC
        LIMIT #{pageSize} OFFSET #{offset}
    </select>

    <select id="countList" resultType="java.lang.Long">
        SELECT COUNT(1) FROM news
        <where>
            deleted = 0
            <if test="keyword != null and keyword != ''">
                AND (
                title LIKE CONCAT('%', #{keyword}, '%')
                OR summary LIKE CONCAT('%', #{keyword}, '%')
                OR title_cn LIKE CONCAT('%', #{keyword}, '%')
                OR summary_cn LIKE CONCAT('%', #{keyword}, '%')
                )
            </if>
            <if test="source != null and source != ''">
                AND source = #{source}
            </if>
            <if test="category != null and category != ''">
                AND category = #{category}
            </if>
        </where>
    </select>

    <select id="selectDetailById" resultMap="resultNewsMap">
        SELECT * FROM news
        WHERE id = #{id}
          AND deleted = 0
        LIMIT 1
    </select>

</mapper>
